<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Frost Fleet | Elite Hub</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { 
            --red: #E62411; --bg: #111111; --card: #1d1f20; --text: #f4f7f6; --border: #333; --active: #28a745; --payroll: #f39c12;
        }
        [data-theme="light"] {
            --bg: #f4f7f6; --card: #ffffff; --text: #2d3436; --border: #edf2f7;
        }

        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: var(--bg); margin: 0; display: flex; height: 100vh; color: var(--text); transition: background 0.3s; overflow: hidden; }
        .sidebar { width: 320px; background: var(--card); border-right: 2px solid var(--border); display: flex; flex-direction: column; z-index: 10; }
        .sidebar-header { padding: 25px; border-bottom: 1px solid var(--border); font-weight: 900; color: var(--red); text-transform: uppercase; letter-spacing: 1px; font-size: 1.2rem; }
        .sidebar-content { flex: 1; padding: 20px; overflow-y: auto; font-size: 13px; color: #888; line-height: 1.6; }
        .sidebar-content strong { color: var(--text); }

        .map-dock { height: 320px; border-top: 3px solid var(--red); background: #000; position: relative; overflow: hidden; }
        #sidebar-map { width: 100%; height: 100%; border: none; display: none; }
        .map-placeholder { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: #444; font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; width: 80%; }

        .main-wrapper { flex: 1; display: flex; flex-direction: column; overflow-y: auto; padding: 25px; }
        .header { display: flex; justify-content: space-between; align-items: center; background: var(--card); padding: 20px 30px; border-radius: 12px; border-bottom: 5px solid var(--red); margin-bottom: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .logo { font-size: 26px; font-weight: 900; text-transform: uppercase; letter-spacing: -1px; }
        .logo span { color: var(--red); }

        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; margin-bottom: 25px; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 10px; border-left: 5px solid #333; }
        .stat-card h3 { margin: 0; font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 1px; }
        .stat-card p { margin: 10px 0 0; font-size: 32px; font-weight: 800; }

        .table-container { background: var(--card); border-radius: 12px; overflow-x: auto; box-shadow: 0 15px 35px rgba(0,0,0,0.4); border: 1px solid var(--border); }
        table { width: 100%; border-collapse: collapse; min-width: 1000px; }
        th { background: rgba(255,255,255,0.02); padding: 18px; font-size: 11px; text-transform: uppercase; color: #777; border-bottom: 2px solid var(--border); text-align: left; }
        td { padding: 16px 18px; border-bottom: 1px solid var(--border); font-size: 14px; }

        .badge { padding: 5px 10px; border-radius: 4px; font-size: 10px; font-weight: 900; text-transform: uppercase; }
        .badge-active { background: var(--active); color: white; }
        .map-link { color: #3498db; text-decoration: none; font-weight: 800; cursor: pointer; border-bottom: 1px dashed #3498db; }
        .btn { background: var(--red); color: white; border: none; padding: 12px 20px; border-radius: 6px; font-weight: 700; cursor: pointer; margin-left: 10px; text-transform: uppercase; font-size: 11px; }
    </style>
</head>
<body data-theme="dark">

    <aside class="sidebar">
        <div class="sidebar-header">Frost Tracker</div>
        <div class="sidebar-content" id="sidebar-info">
            <p><strong>Fleet Engine:</strong> Active</p>
            <p>Scanning Supabase <code>fleet_logs</code> table.</p>
            <p>Tracking Weekly Hours (Mon-Sun) and 15hr infringements.</p>
        </div>
        <div class="map-dock">
            <div class="map-placeholder" id="map-text">SATELLITE STANDBY</div>
            <iframe id="sidebar-map" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </aside>

    <div class="main-wrapper">
        <div class="header">
            <div class="logo">Frost<span>Fleet</span> Elite</div>
            <div>
                <button class="btn" style="background:#444" onclick="toggleTheme()" id="themeBtn">☀️ Light Mode</button>
                <button class="btn" onclick="loadData()">🔄 Refresh Fleet</button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card"><h3>Total Drivers</h3><p id="stat-total">0</p></div>
            <div class="stat-card" style="border-left-color: var(--active)"><h3>On Duty</h3><p id="stat-active" style="color: var(--active)">0</p></div>
            <div class="stat-card" style="border-left-color: var(--red)"><h3>15hr Shifts</h3><p id="stat-long" style="color: var(--red)">0</p></div>
            <div class="stat-card" style="border-left-color: var(--payroll)"><h3>Nights Out</h3><p id="stat-nights" style="color: var(--payroll)">0</p></div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Driver</th>
                        <th>Status</th>
                        <th>This Week Hours</th>
                        <th>15hr Usage</th>
                        <th>Nights Out</th>
                        <th>Last Action</th>
                        <th>GPS Location</th>
                    </tr>
                </thead>
                <tbody id="table-body"></tbody>
            </table>
        </div>
    </div>

    <script>
        // CONFIG
        const SUPABASE_URL = "https://mbudwnwxucluwgbkgbfx.supabase.co"; 
        const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1idWR3bnd4dWNsdXdnYmtnYmZ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyMDQwMjYsImV4cCI6MjA5MDc4MDAyNn0.xFv-FiQ894vdfJuQYWQyF4WzQXmlnmnKvz_c8nuzl5Q"; 
        
        const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        function toggleTheme() {
            const isDark = document.body.getAttribute('data-theme') === 'dark';
            document.body.setAttribute('data-theme', isDark ? 'light' : 'dark');
            document.getElementById('themeBtn').innerText = isDark ? "🌙 Night Mode" : "☀️ Light Mode";
        }

        function updateDock(coords, name) {
            const mapFrame = document.getElementById('sidebar-map');
            document.getElementById('map-text').style.display = "none";
            mapFrame.style.display = "block";
            // FIXED MAP URL
            mapFrame.src = `https://maps.google.com/maps?q=${coords}&t=k&z=15&output=embed`;
            
            document.getElementById('sidebar-info').innerHTML = `
                <div style="background:var(--red);padding:15px;border-radius:8px;color:white;">
                    <small>TRACKING UNIT:</small><br>
                    <strong>${name.toUpperCase()}</strong><br>
                    <a href="https://www.google.com/maps?q=${coords}" target="_blank" style="color:white; font-size:10px; text-decoration:underline;">External Link</a>
                </div>
            `;
        }

        async function loadData() {
            const tbody = document.getElementById('table-body');
            tbody.innerHTML = "<tr><td colspan='7' style='text-align:center; padding:50px; color:#888;'>CONNECTING TO DATABASE...</td></tr>";

            try {
                // Get start of this week (Monday)
                const now = new Date();
                const day = now.getDay();
                const diff = now.getDate() - day + (day === 0 ? -6 : 1);
                const monday = new Date(now.setDate(diff));
                monday.setHours(0,0,0,0);

                // Fetch logs from Supabase
                const { data: logs, error } = await _supabase
                    .from('fleet_logs')
                    .select('*')
                    .gte('created_at', monday.toISOString())
                    .order('created_at', { ascending: true });

                if (error) throw error;

                const report = {};
                let activeDrivers = 0, total15hrs = 0, totalNights = 0;

                logs.forEach(log => {
                    const name = log.driver_name;
                    if (!report[name]) {
                        report[name] = { totalMs: 0, lastStart: null, status: 'OFFLINE', longShifts: 0, nights: 0, lastLoc: log.coordinates, lastTime: '' };
                    }

                    if (log.action_type === 'START') {
                        report[name].lastStart = new Date(log.created_at);
                        report[name].status = 'ACTIVE';
                    } 
                    else if (log.action_type === 'END' && report[name].lastStart) {
                        const shiftMs = new Date(log.created_at) - report[name].lastStart;
                        report[name].totalMs += shiftMs;
                        if (shiftMs > (15 * 60 * 60 * 1000)) report[name].longShifts++;
                        report[name].lastStart = null;
                        report[name].status = 'OFFLINE';
                    } 
                    else if (log.action_type === 'NIGHT OUT') {
                        report[name].nights++;
                    }

                    report[name].lastLoc = log.coordinates;
                    report[name].lastTime = new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                });

                tbody.innerHTML = "";
                const names = Object.keys(report);
                
                if (names.length === 0) {
                    tbody.innerHTML = "<tr><td colspan='7' style='text-align:center; padding:50px;'>No data found for this week.</td></tr>";
                }

                names.forEach(name => {
                    const d = report[name];
                    if (d.status === 'ACTIVE') activeDrivers++;
                    total15hrs += d.longShifts;
                    totalNights += d.nights;

                    tbody.innerHTML += `
                        <tr>
                            <td><strong>${name.toUpperCase()}</strong></td>
                            <td><span class="badge ${d.status === 'ACTIVE' ? 'badge-active' : ''}" style="background:${d.status === 'ACTIVE' ? '' : '#444'}">${d.status}</span></td>
                            <td style="font-weight:700;">${(d.totalMs / (1000 * 60 * 60)).toFixed(2)}h</td>
                            <td style="color:${d.longShifts >= 3 ? 'var(--red)' : 'inherit'}; font-weight:bold;">${d.longShifts}/3</td>
                            <td>${d.nights}</td>
                            <td style="opacity:0.6">${d.lastTime}</td>
                            <td><span class="map-link" onclick="updateDock('${d.lastLoc}', '${name}')">📍 View GPS</span></td>
                        </tr>
                    `;
                });

                document.getElementById('stat-total').innerText = names.length;
                document.getElementById('stat-active').innerText = activeDrivers;
                document.getElementById('stat-long').innerText = total15hrs;
                document.getElementById('stat-nights').innerText = totalNights;

            } catch (err) {
                console.error(err);
                tbody.innerHTML = `<tr><td colspan='7' style='color:red; text-align:center; padding:30px;'><strong>DATABASE ERROR:</strong><br>${err.message}</td></tr>`;
            }
        }

        window.onload = loadData;
        setInterval(loadData, 60000); // Auto-refresh every 60 seconds
    </script>
</body>
</html>
